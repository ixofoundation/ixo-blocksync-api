# --- required ---
# Read access to the blocksync (indexer-written) database
DATABASE_URL=postgres://user:password@host:5432/blocksync

# --- optional ---
PORT=8081
NODE_ENV=development
# 1 to connect to Postgres over SSL (rejectUnauthorized=false, matching ixo-blocksync)
DATABASE_USE_SSL=0
# Postgres schema exposed over GraphQL
DATABASE_SCHEMA=public
# Max clients in the single shared pg pool (PostGraphile + custom loaders)
DB_POOL_MAX=15
# statement_timeout applied to every GraphQL-issued query (ms)
STATEMENT_TIMEOUT_MS=4000
# express-rate-limit: window + max requests per IP per window
RATE_LIMIT_WINDOW_MS=1000
RATE_LIMIT_MAX=200
# express "trust proxy" value
TRUST_PROXY=1
# Rewrites ipfs service endpoints on Entity.service (same as ixo-blocksync)
IPFS_SERVICE_MAPPING=
# IPFS gateway used by GET /api/ipfs/:cid
IPFS_GATEWAY=https://ipfs.gateway.ixo.world
# Chain RPC endpoint - only needed for the tokenomics* GraphQL fields
RPC=
# Where to export the GraphQL SDL on boot (empty to disable)
EXPORT_SCHEMA_PATH=public/graphql/schema.graphql

# Block-aware response cache: flushed the instant the indexer commits a block
# (pg_notify trigger from scripts/block-notify-trigger.sql + poll backstop),
# so cached responses are never staler than the database. 0 to disable.
BLOCK_CACHE=1
# LISTEN/NOTIFY does not work through pgbouncer transaction pooling; point
# this at the DIRECT postgres service for instant invalidation (otherwise the
# BLOCK_CACHE_BACKSTOP_MS poll bounds staleness instead)
BLOCK_CACHE_LISTEN_DATABASE_URL=
BLOCK_CACHE_CHANNEL=blocksync_new_block
BLOCK_CACHE_MAX_ENTRIES=500
BLOCK_CACHE_MAX_ENTRY_BYTES=2097152
BLOCK_CACHE_BACKSTOP_MS=5000
